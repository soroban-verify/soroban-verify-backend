# --- Shared -----------------------------------------------------------------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/soroban_verify

# --- API --------------------------------------------------------------------
API_BIND_ADDR=0.0.0.0:8080

# --- Soroban RPC ------------------------------------------------------------
# Testnet has a free public SDF endpoint; mainnet requires your own provider.
RPC_URL_TESTNET=https://soroban-testnet.stellar.org
RPC_URL_MAINNET=

# --- Worker -----------------------------------------------------------------
WORKER_POLL_INTERVAL_MS=1000
MAX_CONCURRENT_BUILDS=2
BUILD_TIMEOUT_SECS=1800
BUILD_SCRATCH_DIR=./builds

# Default build image used when the submitter does not pin one.
# MUST be digest-pinned in production (see SECURITY.md).
DEFAULT_BUILD_IMAGE=docker.io/stellar/stellar-contract-build:latest

# Comma-separated sha256 digests of SDF-allowlisted trusted images (tier: trusted).
TRUSTED_IMAGE_DIGESTS=

# Comma-separated registry/namespace prefixes considered publicly auditable
# (tier: auditable). Anything else is tier: deployer_supplied.
AUDITABLE_IMAGE_REGISTRIES=docker.io/stellar/
